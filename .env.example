OPENAI_API_KEY=your_api_key_here
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
SIMILARITY_THRESHOLD=0.92
MIN_PERSONAL_SAMPLE_SIZE=3

# Optional: only needed if a request sets "provider": "anthropic" or "gemini".
# Embeddings/dedup always use OpenAI regardless of the chosen provider, so
# OPENAI_API_KEY above is still required either way.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Optional: only needed if you pass "country" in the request to get
# seasonal/occasion-aware subject lines (Christmas, Black Friday, etc).
CALENDARIFIC_API_KEY=your_calendarific_api_key_here
OCCASION_LOOKAHEAD_DAYS=30
OCCASION_CACHE_TTL_SECONDS=86400
